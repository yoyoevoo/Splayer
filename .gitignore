# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# env files (never commit real credentials)
.env
.env.local
.env.*.local
.env.development
.env.production
.env.staging
.env.test

# Claude Code local settings (may contain shell commands with credentials)
**/.claude/settings.local.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit platform files — workspace config, agent metadata, dev-chat assets
.replit
.replitignore
replit.md
.agents/
attached_assets/
**/.replit-artifact/
.cache/
.local/
artifacts/music-player/release/
artifacts/music-player/node_modules/

# Dead scaffolding — never re-track these directories
artifacts/api-server/
artifacts/mockup-sandbox/
lib/

# Native binaries and installer packages — large and platform-specific
artifacts/music-player/android/app/src/main/jniLibs/
artifacts/music-player/resources/
**/*.so
**/*.dylib
*.deb
*.rpm
*.AppImage
*.dmg
*.exe
*.msi

# Release APK build artifacts (attach to GitHub release instead)
artifacts/music-player/*.apk

# Release signing keystore — never commit private keys
artifacts/music-player/android/keystore/*.jks
artifacts/music-player/android/keystore/*.keystore

# Backup files
**/*.bak
**/*.bak2
releases/*.apk
