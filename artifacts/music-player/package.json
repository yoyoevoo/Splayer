{
  "name": "@workspace/music-player",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --config vite.config.ts --host 0.0.0.0",
    "build": "vite build --config vite.config.ts",
    "build:desktop": "BASE_PATH=./ PORT=5173 vite build --config vite.config.ts",
    "serve": "vite preview --config vite.config.ts --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "pnpm run build:desktop && electron . --no-sandbox",
    "electron": "pnpm run build:desktop && electron . --no-sandbox",
    "dist:linux": "pnpm run build:desktop && electron-builder --linux AppImage --x64",
    "dist:win": "node scripts/prepare-win.mjs && pnpm run build:desktop && electron-builder --win nsis --x64",
    "build:win": "node scripts/prepare-win.mjs && pnpm run build:desktop && electron-builder --win nsis --x64",
    "build:portable": "node scripts/prepare-win.mjs && pnpm run build:desktop && electron-builder --win portable --x64",
    "build:android": "BASE_PATH=./ PORT=5173 vite build --config vite.config.ts && cap sync android",
    "open:android": "cap open android"
  },
  "build": {
    "appId": "com.replit.splayer",
    "productName": "Splayer",
    "asar": true,
    "afterPack": "build/after-pack.cjs",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/yt-dlp",
        "to": "yt-dlp"
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "icon": "build/icon.png",
      "executableName": "Splayer",
      "extraResources": [
        {
          "from": "resources/yt-dlp.exe",
          "to": "yt-dlp.exe"
        },
        {
          "from": "resources/ffmpeg.exe",
          "to": "ffmpeg.exe"
        }
      ],
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Splayer_Setup.exe",
      "shortcutName": "Splayer",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "menuCategory": "Splayer"
    },
    "portable": {
      "artifactName": "Splayer_Portable.exe"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "AudioVideo;Audio;Player",
      "executableName": "splayer",
      "icon": "build/icon.png",
      "synopsis": "A focused local music player",
      "description": "Play your downloaded music with embedded cover art or your own custom covers."
    }
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-accordion": "^1.2.4",
    "@radix-ui/react-alert-dialog": "^1.1.7",
    "@radix-ui/react-aspect-ratio": "^1.1.3",
    "@radix-ui/react-avatar": "^1.1.4",
    "@radix-ui/react-checkbox": "^1.1.5",
    "@radix-ui/react-collapsible": "^1.1.4",
    "@radix-ui/react-context-menu": "^2.2.7",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-hover-card": "^1.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-menubar": "^1.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.6",
    "@radix-ui/react-popover": "^1.1.7",
    "@radix-ui/react-progress": "^1.1.3",
    "@radix-ui/react-radio-group": "^1.2.4",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slider": "^1.2.4",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-toggle": "^1.1.3",
    "@radix-ui/react-toggle-group": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@replit/vite-plugin-cartographer": "catalog:",
    "@replit/vite-plugin-dev-banner": "catalog:",
    "@replit/vite-plugin-runtime-error-modal": "catalog:",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/react-query": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "cmdk": "^1.1.1",
    "date-fns": "^3.6.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "catalog:",
    "input-otp": "^1.4.2",
    "lucide-react": "catalog:",
    "next-themes": "^0.4.6",
    "react": "catalog:",
    "react-day-picker": "^9.11.1",
    "react-dom": "catalog:",
    "react-hook-form": "^7.55.0",
    "react-icons": "^5.4.0",
    "react-resizable-panels": "^2.1.7",
    "recharts": "^2.15.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "vite": "catalog:",
    "wouter": "^3.3.5",
    "zod": "catalog:"
  },
  "dependencies": {
    "@capacitor-community/http": "^1.4.1",
    "@capacitor/android": "^8.3.1",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.3.1",
    "@capacitor/filesystem": "^8.1.2",
    "@distube/ytdl-core": "^4.16.12",
    "@tanstack/react-virtual": "^3.13.24",
    "astral-regex": "^2.0.0",
    "browser-id3-writer": "^6.3.1",
    "discord-rpc": "^4.0.1",
    "dotenv": "^17.4.2",
    "idb": "^8.0.3",
    "jsmediatags": "^3.9.7",
    "mpris-service": "^2.1.2",
    "youtube-search-api": "^2.0.1",
    "yt-search": "^2.13.1"
  },
  "optionalDependencies": {
    "@jellyfin/windows-media-transport-controls": "*",
    "@workspace/api-client-react": "workspace:*"
  }
}
